# AI Provider: "openai" or "anthropic"
AI_PROVIDER=openai

# API Keys (only need the one matching your provider)
OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here

# Model override (optional — defaults: gpt-4o-mini for OpenAI, claude-sonnet-4-5 for Anthropic)
# AI_MODEL=gpt-4o-mini

# LinkedIn session cookie (optional — adds LinkedIn as a scraping source)
# LINKEDIN_SESSION_COOKIE=your_li_at_cookie_here

# Scoring threshold (0-100). Jobs scoring above this go to review queue.
SCORE_THRESHOLD=72

# Editor for cover letter editing (code, vim, nano, etc.)
EDITOR=code

# Number of parallel AI scoring workers (default: 20)
# SCORE_WORKERS=20
